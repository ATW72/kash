<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anthony SpendTracker</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  --primary: #667eea; --primary-dark: #5568d3; --secondary: #764ba2;
  --success: #10b981; --danger: #ef4444; --warning: #f59e0b;
  --bg-primary: #ffffff; --bg-secondary: #f9fafb;
  --text-primary: #1f2937; --text-secondary: #6b7280; --text-tertiary: #9ca3af;
  --card-bg: #ffffff; --input-bg: #ffffff; --input-border: #e5e7eb;
  --shadow: rgba(0,0,0,0.1);
  --gradient-start: #667eea; --gradient-end: #764ba2;
  --border: #e5e7eb;
}
body.dark-mode {
  --bg-primary: #1a1a2e; --bg-secondary: #16213e;
  --text-primary: #e4e4e7; --text-secondary: #a1a1aa; --text-tertiary: #71717a;
  --card-bg: #0f3460; --input-bg: #16213e; --input-border: rgba(255,255,255,0.1);
  --shadow: rgba(0,0,0,0.3); --border: rgba(255,255,255,0.1);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg-secondary); color: var(--text-primary); transition: all 0.3s; }
/* ── Header ── */
.header {
  background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
  padding: 1rem 1.5rem; display: flex; align-items: center;
  justify-content: space-between; box-shadow: 0 4px 20px rgba(102,126,234,0.4);
  position: sticky; top: 0; z-index: 100;
}
.header h1 { color: white; font-size: 1.4rem; font-weight: 800; }
.header-right { display: flex; gap: 0.75rem; align-items: center; }
.header-right span { color: rgba(255,255,255,0.85); font-size: 0.85rem; }
#theme-toggle { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);
  color: white; border-radius: 50%; width: 36px; height: 36px; cursor: pointer;
  font-size: 1rem; display: flex; align-items: center; justify-content: center; }
#theme-toggle:hover { background: rgba(255,255,255,0.3); }
.btn-logout { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
  color: white; padding: 0.4rem 0.9rem; border-radius: 8px; cursor: pointer; font-size: 0.85rem; }
/* ── Tabs ── */
.tabs { display: flex; overflow-x: auto; background: var(--bg-primary);
  border-bottom: 2px solid var(--border); padding: 0 1rem; gap: 0.25rem;
  scrollbar-width: none; }
.tabs::-webkit-scrollbar { display: none; }
.tab-button { background: none; border: none; color: var(--text-secondary);
  padding: 0.9rem 1.1rem; cursor: pointer; font-size: 0.9rem; font-weight: 600;
  white-space: nowrap; border-bottom: 3px solid transparent; margin-bottom: -2px;
  transition: all 0.2s; }
.tab-button:hover { color: var(--primary); }
.tab-button.active { color: var(--primary); border-bottom-color: var(--primary); }
/* ── Content ── */
.main { padding: 1.5rem; max-width: 1200px; margin: 0 auto; }
.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
/* ── Cards ── */
.glass-card {
  background: var(--card-bg); border-radius: 16px;
  box-shadow: 0 4px 24px var(--shadow); border: 1px solid var(--border);
  padding: 1.5rem; transition: transform 0.3s, box-shadow 0.3s; margin-bottom: 1.25rem;
}
.glass-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px var(--shadow); }
.card-title { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;
  display: flex; align-items: center; gap: 0.5rem; }
/* ── Stat Cards ── */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
.stat-card { background: var(--card-bg); border-radius: 14px; padding: 1.25rem;
  border: 1px solid var(--border); box-shadow: 0 2px 12px var(--shadow); }
.stat-card h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
  color: var(--text-secondary); margin-bottom: 0.5rem; }
.stat-card p { font-size: 1.5rem; font-weight: 800; color: var(--primary); }
.stat-card p.danger { color: var(--danger); }
.stat-card p.success { color: var(--success); }
/* ── Forms ── */
.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.35rem; }
label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
input, select, textarea {
  background: var(--input-bg); border: 1.5px solid var(--input-border);
  border-radius: 10px; padding: 0.65rem 0.9rem; font-size: 0.95rem;
  color: var(--text-primary); outline: none; transition: border-color 0.2s; width: 100%;
}
input:focus, select:focus, textarea:focus { border-color: var(--primary); }
input.error, select.error { border-color: var(--danger); }
.field-error { color: var(--danger); font-size: 0.78rem; margin-top: 0.2rem; }
textarea { resize: vertical; min-height: 60px; }
/* ── Buttons ── */
button, .btn {
  background: linear-gradient(90deg, #4f8cff, #6f6fff);
  color: white; border: none; border-radius: 10px; padding: 0.65rem 1.3rem;
  font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s;
  position: relative; overflow: hidden;
}
button:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(79,140,255,0.3); }
button:active:not(:disabled) { transform: scale(0.98); }
button:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-danger { background: linear-gradient(90deg, var(--danger), #c0392b); }
.btn-success { background: linear-gradient(90deg, var(--success), #059669); }
.btn-warning { background: linear-gradient(90deg, var(--warning), #d97706); }
.btn-secondary { background: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border); }
.btn-sm { padding: 0.35rem 0.75rem; font-size: 0.82rem; border-radius: 8px; }
/* ── Tables / Lists ── */
.expense-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.expense-table th { background: var(--bg-secondary); color: var(--text-secondary); font-weight: 600;
  padding: 0.7rem 0.9rem; text-align: left; font-size: 0.8rem; text-transform: uppercase; }
.expense-table td { padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--border); }
.expense-table tr:hover td { background: var(--bg-secondary); }
.amount-positive { color: var(--success); font-weight: 700; }
.amount-negative { color: var(--danger); font-weight: 700; }
/* ── Credit Card Grid ── */
.credit-card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
.cc-card { background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
  border-radius: 18px; padding: 1.5rem; color: white;
  box-shadow: 0 8px 32px rgba(102,126,234,0.4); position: relative; overflow: hidden; }
.cc-card::before { content:''; position:absolute; top:-50%; right:-20%; width:200px; height:200px;
  background:rgba(255,255,255,0.08); border-radius:50%; }
.cc-card .cc-name { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.25rem; }
.cc-card .cc-owner { font-size: 0.8rem; opacity: 0.8; margin-bottom: 1rem; }
.cc-card .cc-balance { font-size: 1.8rem; font-weight: 800; }
.cc-card .cc-limit { font-size: 0.82rem; opacity: 0.8; margin-top: 0.2rem; }
.cc-card .cc-util-bar { background: rgba(255,255,255,0.2); border-radius: 4px; height: 6px; margin-top: 1rem; overflow: hidden; }
.cc-card .cc-util-fill { background: white; height: 100%; border-radius: 4px; transition: width 0.5s; }
.cc-card .cc-util-fill.danger { background: #fca5a5; }
.cc-card .cc-actions { display: flex; gap: 0.5rem; margin-top: 1rem; }
.cc-card .cc-actions button { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4);
  color: white; padding: 0.3rem 0.7rem; border-radius: 8px; font-size: 0.8rem; }
/* ── Budget ── */
.budget-item { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px;
  padding: 1rem 1.25rem; margin-bottom: 0.75rem; }
.budget-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
.budget-progress { height: 10px; background: var(--bg-secondary); border-radius: 5px; overflow: hidden; }
.budget-fill { height: 100%; border-radius: 5px; transition: width 0.5s;
  background: linear-gradient(90deg, var(--primary), var(--secondary)); }
.budget-fill.over { background: linear-gradient(90deg, var(--danger), #c0392b); }
/* ── Bills ── */
.bill-item { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px;
  padding: 1rem 1.25rem; margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; }
.bill-item.paid { opacity: 0.6; }
.bill-due { font-size: 0.82rem; color: var(--text-secondary); }
.bill-due.overdue { color: var(--danger); font-weight: 700; }
.bill-due.soon { color: var(--warning); font-weight: 600; }
/* ── Toast ── */
#toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }
.toast { min-width: 280px; background: var(--card-bg); border-radius: 12px;
  box-shadow: 0 4px 24px var(--shadow); border-left: 4px solid var(--primary); overflow: hidden;
  animation: slideIn 0.3s ease; }
.toast.success { border-left-color: var(--success); }
.toast.error { border-left-color: var(--danger); }
.toast.warning { border-left-color: var(--warning); }
.toast.fade-out { animation: slideOut 0.3s ease forwards; }
.toast-header { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0.9rem 0; }
.toast-title { font-weight: 700; font-size: 0.85rem; color: var(--text-primary); }
.toast-close { background: none; border: none; color: var(--text-tertiary); cursor: pointer;
  font-size: 0.9rem; padding: 0; }
.toast-body { padding: 0.4rem 0.9rem 0.7rem; font-size: 0.88rem; color: var(--text-secondary); }
@keyframes slideIn { from { transform: translateX(110%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
@keyframes slideOut { to { transform: translateX(110%); opacity: 0; } }
/* ── Modal ── */
.modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; }
.modal-backdrop.active { display: flex; align-items: center; justify-content: center; }
.modal { background: var(--card-bg); border-radius: 18px; padding: 2rem; min-width: 320px;
  max-width: 90vw; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
.modal h3 { margin-bottom: 0.75rem; font-size: 1.1rem; }
.modal p { color: var(--text-secondary); margin-bottom: 1.5rem; }
.modal-btns { display: flex; gap: 0.75rem; justify-content: flex-end; }
/* ── Misc ── */
.gradient-text { background: linear-gradient(90deg, var(--gradient-start), var(--gradient-end));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 800; }
.empty-state { text-align: center; padding: 3rem; color: var(--text-tertiary); }
.empty-state .icon { font-size: 3rem; margin-bottom: 0.75rem; }
.badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
.badge-success { background: rgba(16,185,129,0.15); color: var(--success); }
.badge-danger { background: rgba(239,68,68,0.15); color: var(--danger); }
.badge-warning { background: rgba(245,158,11,0.15); color: var(--warning); }
.badge-primary { background: rgba(102,126,234,0.15); color: var(--primary); }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-gap { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
.section-title { font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.overflow-table { overflow-x: auto; }
/* ── Collapsible sections ── */
.collapsible-card { padding: 0; overflow: hidden; }
.collapsible-header { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem; cursor: pointer; user-select: none; }
.collapsible-header:hover { background: var(--bg-secondary); }
.collapsible-body { padding: 0 1.5rem 1.5rem; border-top: 1px solid var(--border); }
.collapsible-body.collapsed { display: none; }
.collapse-arrow { color: var(--text-secondary); font-size: 0.85rem; transition: transform 0.2s; }
.collapse-arrow.collapsed { transform: rotate(-90deg); }
.filter-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem; }
.filter-row input, .filter-row select { flex: 1; min-width: 140px; }
@media (max-width: 640px) {
  .main { padding: 1rem; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .form-grid { grid-template-columns: 1fr; }
  .credit-card-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<!-- Header -->
<div class="header">
  <h1>💰 SpendTracker</h1>
  <div class="header-right">
    <span id="user-greeting">Hello!</span>
    <button id="theme-toggle" onclick="toggleTheme()" title="Toggle dark mode">🌙</button>
    <button class="btn-logout" onclick="doLogout()">Logout</button>
  </div>
</div>

<!-- Tabs -->
<div class="tabs">
  <button class="tab-button active" data-tab="dashboard">📊 Dashboard</button>
  <button class="tab-button" data-tab="spending">💸 Spending</button>
  <button class="tab-button" data-tab="income">💵 Income</button>
  <button class="tab-button" data-tab="credit-cards">💳 Credit Cards</button>
  <button class="tab-button" data-tab="budgets">🎯 Budgets</button>
  
  
  <button class="tab-button" data-tab="reports">📈 Reports</button>
  <button class="tab-button" data-tab="account">⚙️ Account</button>
</div>

<!-- Toast Container -->
<div id="toast-container"></div>

<!-- Modal -->
<div class="modal-backdrop" id="modal-backdrop">
  <div class="modal" id="modal-container">
    <h3 id="modal-title">Confirm</h3>
    <p id="modal-body">Are you sure?</p>
    <div class="modal-btns">
      <button class="btn-secondary btn-sm" onclick="hideModal()">Cancel</button>
      <button class="btn-danger btn-sm" id="modal-confirm-btn">Confirm</button>
    </div>
  </div>
</div>

<div class="main">

<!-- ═══════════════ DASHBOARD ═══════════════ -->
<div class="tab-content active" id="dashboard-tab">
  <div class="stats-grid" id="dashboard-stats">
    <div class="stat-card"><h3>Monthly Expenses</h3><p id="stat-monthly-expenses">$0.00</p></div>
    <div class="stat-card"><h3>Monthly Income</h3><p id="stat-monthly-income" class="success">$0.00</p></div>
    <div class="stat-card"><h3>Left After Bills</h3><p id="stat-left-after-bills">$0.00</p></div>
    <div class="stat-card"><h3>Unpaid Bills</h3><p id="stat-unpaid-bills" class="danger">$0.00</p></div>
    <div class="stat-card"><h3>Total Credit Card Balance</h3><p id="stat-cc-balance" class="danger">$0.00</p></div>
    <div class="stat-card"><h3>All-Time Income</h3><p id="stat-total-income" class="success">$0.00</p></div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; flex-wrap:wrap;">
    <div class="glass-card">
      <div class="card-title">📊 Monthly Trend</div>
      <canvas id="trend-chart" height="200"></canvas>
    </div>
    <div class="glass-card">
      <div class="card-title">🍕 Spending by Category</div>
      <canvas id="category-chart" height="200"></canvas>
    </div>
  </div>
</div>

<!-- ═══════════════ SPENDING ═══════════════ -->
<div class="tab-content" id="spending-tab">
  <div class="glass-card">
    <div class="card-title">➕ Add Expense</div>
    <form id="expense-form" onsubmit="submitExpenseForm(event)">
      <div class="form-grid">
        <div class="form-group"><label>Date *</label><input type="date" id="expense-date" required></div>
        <div class="form-group"><label>Category *</label><select id="expense-category" required><option value="">-- Category --</option></select></div>
        <div class="form-group"><label>Description *</label><input type="text" id="expense-description" placeholder="What was purchased?" required></div>
        <div class="form-group"><label>Amount *</label><input type="number" id="expense-amount" step="0.01" min="0.01" placeholder="0.00" required></div>
        <div class="form-group"><label>Paid By *</label>
          <select id="expense-paid-by" required>
            <option value="">-- Person --</option>
          </select>
        </div>
        <div class="form-group"><label>Payment Method</label>
          <select id="expense-payment-method">
            <option value="">-- Method --</option>
            <option value="Cash">Cash</option>
            <option value="Credit">Credit</option>
            <option value="Debit">Debit</option>
          </select>
        </div>
        <div class="form-group"><label>Credit Card</label><select id="expense-credit-card"><option value="">-- None --</option></select></div>
        <div class="form-group"><label>Notes</label><textarea id="expense-notes" rows="2" placeholder="Optional notes..."></textarea></div>
      </div>
      <div style="margin-top:1rem; display:flex; gap:0.75rem;">
        <button type="submit" id="expense-submit-btn">💾 Add Expense</button>
        <button type="button" class="btn-secondary" onclick="cancelExpenseEdit()">Cancel</button>
      </div>
      <input type="hidden" id="expense-edit-id">
    </form>
  </div>
  <div class="glass-card">
    <div class="section-header">
      <span class="section-title">Expense History</span>
      <div class="flex-gap">
        <button class="btn-sm btn-success" onclick="exportExpensesCSV()">📄 CSV</button>
        <button class="btn-sm" style="background:linear-gradient(90deg,#217346,#1a5c37)" onclick="exportExpensesExcel()">📊 Excel</button>
      </div>
    </div>
    <div class="filter-row">
      <input type="date" id="expense-filter-start" placeholder="From">
      <input type="date" id="expense-filter-end" placeholder="To">
      <select id="expense-filter-category"><option value="">All Categories</option></select>
      <button class="btn-sm" onclick="loadExpenses()">🔍 Filter</button>
      <button class="btn-sm btn-secondary" onclick="clearExpenseFilter()">✕ Clear</button>
    </div>
    <div class="overflow-table"><table class="expense-table">
      <thead><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th><th>Paid By</th><th>Method</th><th>Actions</th></tr></thead>
      <tbody id="expense-list"><tr><td colspan="7" class="empty-state"><div class="icon">💸</div>No expenses yet</td></tr></tbody>
    </table></div>
  </div>
</div>

<!-- ═══════════════ INCOME ═══════════════ -->
<div class="tab-content" id="income-tab">
  <div class="glass-card">
    <div class="card-title">➕ Add Income</div>
    <form id="income-form" onsubmit="submitIncomeForm(event)">
      <div class="form-grid">
        <div class="form-group"><label>Date *</label><input type="date" id="income-date" required></div>
        <div class="form-group"><label>Source *</label>
          <select id="income-source" required>
            <option value="">-- Source --</option>
            <option value="Salary">Salary</option>
            <option value="Bonus">Bonus</option>
            <option value="Investment">Investment</option>
            <option value="Gift">Gift</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="form-group"><label>Description *</label><input type="text" id="income-description" placeholder="Description" required></div>
        <div class="form-group"><label>Amount *</label><input type="number" id="income-amount" step="0.01" min="0.01" placeholder="0.00" required></div>
        <div class="form-group"><label>Received By *</label>
          <select id="income-received-by" required>
            <option value="">-- Person --</option>
          </select>
        </div>
        <div class="form-group"><label>Notes</label><textarea id="income-notes" rows="2"></textarea></div>
      </div>
      <div style="margin-top:1rem; display:flex; gap:0.75rem;">
        <button type="submit" id="income-submit-btn">💾 Add Income</button>
        <button type="button" class="btn-secondary" onclick="cancelIncomeEdit()">Cancel</button>
      </div>
      <input type="hidden" id="income-edit-id">
    </form>
  </div>
  <div class="glass-card">
    <div class="section-header">
      <span class="section-title">Income History</span>
      <button class="btn-sm btn-success" onclick="exportIncomeCSV()">📄 CSV</button>
    </div>
    <div class="overflow-table"><table class="expense-table">
      <thead><tr><th>Date</th><th>Source</th><th>Description</th><th>Amount</th><th>Received By</th><th>Actions</th></tr></thead>
      <tbody id="income-list"><tr><td colspan="6" class="empty-state"><div class="icon">💵</div>No income yet</td></tr></tbody>
    </table></div>
  </div>
</div>

<!-- ═══════════════ CREDIT CARDS ═══════════════ -->
<div class="tab-content" id="credit-cards-tab">
  <div class="glass-card">
    <div class="card-title">➕ Add Credit Card</div>
    <form id="credit-card-form" onsubmit="submitCreditCardForm(event)">
      <div class="form-grid">
        <div class="form-group"><label>Owner *</label>
          <select id="credit-card-owner" required>
            <option value="">-- Owner --</option>
          </select>
        </div>
        <div class="form-group"><label>Card Name *</label><input type="text" id="credit-card-name" placeholder="e.g. Visa Gold" required></div>
        <div class="form-group"><label>Credit Limit</label><input type="number" id="credit-card-limit" step="0.01" placeholder="Optional"></div>
        <div class="form-group"><label>Manual Balance Override</label><input type="number" id="credit-card-manual-balance" step="0.01" placeholder="Leave blank to auto-calculate"></div>
      </div>
      <button type="submit" style="margin-top:1rem;">💾 Save Card</button>
      <input type="hidden" id="cc-edit-id">
    </form>
  </div>
  <div class="credit-card-grid" id="credit-card-list">
    <div class="empty-state"><div class="icon">💳</div>No credit cards added</div>
  </div>
</div>

<!-- ═══════════════ BUDGETS ═══════════════ -->
<div class="tab-content" id="budgets-tab">
  <div class="glass-card">
    <div class="card-title">➕ Set Budget</div>
    <form id="budget-form" onsubmit="submitBudgetForm(event)">
      <div class="form-grid">
        <div class="form-group"><label>Category *</label><select id="budget-category" required><option value="">-- Category --</option></select></div>
        <div class="form-group"><label>Amount *</label><input type="number" id="budget-amount" step="0.01" min="0.01" placeholder="Budget amount" required></div>
        <div class="form-group"><label>Month *</label>
          <select id="budget-month" required>
            <option value="1">January</option><option value="2">February</option><option value="3">March</option>
            <option value="4">April</option><option value="5">May</option><option value="6">June</option>
            <option value="7">July</option><option value="8">August</option><option value="9">September</option>
            <option value="10">October</option><option value="11">November</option><option value="12">December</option>
          </select>
        </div>
        <div class="form-group"><label>Year *</label><input type="number" id="budget-year" min="2020" max="2099" required></div>
      </div>
      <button type="submit" style="margin-top:1rem;">💾 Set Budget</button>
    </form>
  </div>
  <div id="budget-list"></div>
</div>


<!-- ═══════════════ BILLS SUB-SECTION ═══════════════ -->
<div class="glass-card collapsible-card">
  <div class="collapsible-header" onclick="toggleSection('bills-section')">
    <span class="card-title" style="margin-bottom:0;">📅 Bills <span id="bills-badge" class="badge badge-danger" style="display:none"></span></span>
    <span class="collapse-arrow" id="bills-section-arrow">▼</span>
  </div>
  <div id="bills-section" class="collapsible-body">
    <form id="bill-form" onsubmit="submitBillForm(event)" style="margin-bottom:1.25rem;">
      <div class="form-grid">
        <div class="form-group"><label>Bill Name *</label><input type="text" id="bill-name" placeholder="e.g. Electric Bill" required></div>
        <div class="form-group"><label>Amount *</label><input type="number" id="bill-amount" step="0.01" min="0.01" placeholder="0.00" required></div>
        <div class="form-group"><label>Due Date *</label><input type="date" id="bill-due-date" required></div>
        <div class="form-group"><label>Category</label><select id="bill-category"><option value="">-- Category --</option></select></div>
        <div class="form-group"><label>Notes</label><textarea id="bill-notes" rows="2"></textarea></div>
      </div>
      <button type="submit" style="margin-top:0.75rem;">💾 Add Bill</button>
    </form>
    <div id="bills-list"></div>
  </div>
</div>

<!-- ═══════════════ RECURRING SUB-SECTION ═══════════════ -->
<div class="glass-card collapsible-card">
  <div class="collapsible-header" onclick="toggleSection('recurring-section')">
    <span class="card-title" style="margin-bottom:0;">🔄 Recurring Transactions</span>
    <span class="collapse-arrow" id="recurring-section-arrow">▼</span>
  </div>
  <div id="recurring-section" class="collapsible-body">
    <form id="recurring-form" onsubmit="submitRecurringForm(event)" style="margin-bottom:1.25rem;">
      <div class="form-grid">
        <div class="form-group"><label>Type *</label>
          <select id="rec-type" required>
            <option value="expense">Expense</option>
            <option value="income">Income</option>
          </select>
        </div>
        <div class="form-group"><label>Frequency *</label>
          <select id="rec-frequency" required>
            <option value="weekly">Weekly</option>
            <option value="biweekly">Bi-Weekly</option>
            <option value="monthly">Monthly</option>
            <option value="yearly">Yearly</option>
          </select>
        </div>
        <div class="form-group"><label>Next Date *</label><input type="date" id="rec-next-date" required></div>
        <div class="form-group"><label>Description *</label><input type="text" id="rec-description" required></div>
        <div class="form-group"><label>Amount *</label><input type="number" id="rec-amount" step="0.01" min="0.01" required></div>
        <div class="form-group"><label>Category</label><select id="rec-category"><option value="">-- Category --</option></select></div>
        <div class="form-group"><label>Person *</label>
          <select id="rec-person" required>
            <option value="">-- Person --</option>
          </select>
        </div>
      </div>
      <button type="submit" style="margin-top:0.75rem;">💾 Add Recurring</button>
    </form>
    <div id="recurring-list"></div>
  </div>
</div>

<!-- ═══════════════ REPORTS ═══════════════ -->
<div class="tab-content" id="reports-tab">
  <div class="glass-card">
    <div class="card-title">📊 Generate Report</div>
    <div class="form-grid">
      <div class="form-group"><label>Start Date</label><input type="date" id="report-start"></div>
      <div class="form-group"><label>End Date</label><input type="date" id="report-end"></div>
    </div>
    <div class="flex-gap" style="margin-top:1rem;">
      <button onclick="exportExpensesCSV(true)">📄 Expense CSV</button>
      <button onclick="exportExpensesExcel()">📊 Expense Excel</button>
      <button class="btn-success" onclick="exportIncomeCSV()">💵 Income CSV</button>
    </div>
  </div>
  <div class="glass-card" id="monthly-report-card">
    <div class="card-title">📅 Monthly Summary</div>
    <div id="monthly-report-body"><div class="empty-state">Click to generate...</div></div>
    <button onclick="generateMonthlyReport()" style="margin-top:1rem;">Generate Report</button>
  </div>
</div>

<!-- ═══════════════ ACCOUNT ═══════════════ -->
<div class="tab-content" id="account-tab">
  <div class="glass-card" style="max-width:500px;">
    <div class="card-title">🔒 Change Password</div>
    <form id="password-form" onsubmit="changePassword(event)">
      <div class="form-group"><label>Current Password</label><input type="password" id="current-password" required></div>
      <div class="form-group" style="margin-top:0.75rem;"><label>New Password</label><input type="password" id="new-password" required></div>
      <div class="form-group" style="margin-top:0.75rem;"><label>Confirm New Password</label><input type="password" id="confirm-password" required></div>
      <button type="submit" style="margin-top:1rem;">Update Password</button>
    </form>
  </div>
  <div class="glass-card" id="user-management-card" style="max-width:700px; display:none;">
    <div class="card-title">👥 User Management <span style="font-size:0.8rem;font-weight:400;color:var(--text-secondary)">(Admin Only)</span></div>
    <form id="new-user-form" onsubmit="createUser(event)" style="margin-bottom:1.5rem;">
      <div class="form-grid">
        <div class="form-group"><label>Username</label><input type="text" id="new-username" required></div>
        <div class="form-group"><label>Password</label><input type="password" id="new-user-password" required></div>
        <div class="form-group" style="justify-content:flex-end; padding-top:1.4rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;">
            <input type="checkbox" id="new-user-admin" style="width:auto;"> Admin
          </label>
        </div>
      </div>
      <button type="submit" style="margin-top:0.75rem;">Add User</button>
    </form>
    <div id="users-list"></div>
  </div>
</div>

</div><!-- .main -->

<script>
// ═══════════════════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

function formatCurrency(val) {
  const num = parseFloat(val) || 0;
  return '$' + num.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
}

function formatDate(ds) {
  if (!ds) return '';
  const [y,m,d] = ds.split('-');
  return `${m}/${d}/${y}`;
}

function today() {
  return new Date().toISOString().split('T')[0];
}

function showToast(type='info', message='', title='') {
  const container = document.getElementById('toast-container');
  if (!message) return;
  const titles = {success:'Success', error:'Error', warning:'Warning', info:'Info'};
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `
    <div class="toast-header">
      <div class="toast-title">${title || titles[type] || 'Info'}</div>
      <button class="toast-close" onclick="this.closest('.toast').remove()">✕</button>
    </div>
    <div class="toast-body">${message}</div>`;
  container.appendChild(toast);
  setTimeout(() => { toast.classList.add('fade-out'); setTimeout(()=>toast.remove(), 300); }, 4000);
}

async function apiCall(endpoint, method='GET', data=null) {
  try {
    const opts = { method, headers: {'Content-Type':'application/json'}, credentials: 'same-origin' };
    if (data && method !== 'GET') opts.body = JSON.stringify(data);
    const resp = await fetch(endpoint, opts);
    const result = await resp.json();
    if (!resp.ok) { showToast('error', result.error || 'Operation failed'); return null; }
    return result;
  } catch(e) {
    showToast('error', 'Network error occurred');
    return null;
  }
}

function showModal(title, body, onConfirm) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').textContent = body;
  document.getElementById('modal-backdrop').classList.add('active');
  const btn = document.getElementById('modal-confirm-btn');
  btn.onclick = () => { hideModal(); onConfirm(); };
}
function hideModal() { document.getElementById('modal-backdrop').classList.remove('active'); }

function switchTab(tabName) {
  document.querySelectorAll('.tab-button').forEach(b => b.classList.toggle('active', b.dataset.tab === tabName));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.toggle('active', t.id === `${tabName}-tab`));
  // Lazy-load data
  if (tabName === 'dashboard') loadDashboard();
  if (tabName === 'spending') loadExpenses();
  if (tabName === 'income') loadIncome();
  if (tabName === 'credit-cards') loadCreditCards();
  if (tabName === 'budgets') loadBudgets();
  if (tabName === 'bills') loadBills();
  if (tabName === 'recurring') loadRecurring();
  if (tabName === 'account') loadUsers();
}

document.querySelectorAll('.tab-button').forEach(btn => btn.addEventListener('click', ()=>switchTab(btn.dataset.tab)));

function toggleTheme() {
  document.body.classList.toggle('dark-mode');
  localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
  document.getElementById('theme-toggle').textContent = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
}

async function doLogout() {
  await apiCall('/logout', 'POST');
  window.location.href = '/login';
}

function clearFormErrors() {
  document.querySelectorAll('.error').forEach(e => e.classList.remove('error'));
  document.querySelectorAll('.field-error').forEach(e => e.remove());
}

// ═══════════════════════════════════════════════════════════════════════════
// CATEGORIES & CARDS DROPDOWNS
// ═══════════════════════════════════════════════════════════════════════════

let _categories = [];
let _creditCards = [];

async function loadCategories() {
  const res = await apiCall('/api/categories');
  if (!res) return;
  _categories = res.data;
  ['expense-category','expense-filter-category','budget-category','bill-category','rec-category'].forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    const cur = sel.value;
    sel.innerHTML = id.includes('filter') ? '<option value="">All Categories</option>' : '<option value="">-- Category --</option>';
    _categories.forEach(c => sel.insertAdjacentHTML('beforeend', `<option value="${c}"${c===cur?' selected':''}>${c}</option>`));
  });
}

async function populateUserDropdowns() {
  const res = await apiCall('/api/users/usernames');
  if (!res) return;
  const users = res.data;
  const dropdownIds = ['expense-paid-by', 'income-received-by', 'credit-card-owner', 'rec-person'];
  dropdownIds.forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    // Keep the first placeholder option, replace the rest
    const placeholder = sel.options[0];
    sel.innerHTML = '';
    sel.appendChild(placeholder);
    users.forEach(u => {
      const opt = document.createElement('option');
      opt.value = u;
      opt.textContent = u;
      // Auto-select if it matches the logged-in user
      if (u === currentUser) opt.selected = true;
      sel.appendChild(opt);
    });
  });
}

async function populateCreditCardDropdowns() {
  const res = await apiCall('/api/credit-cards');
  if (!res) return;
  _creditCards = res.data;
  const sel = document.getElementById('expense-credit-card');
  sel.innerHTML = '<option value="">-- None --</option>';
  _creditCards.forEach(c => sel.insertAdjacentHTML('beforeend', `<option value="${c.id}">${c.owner} - ${c.card_name}</option>`));
}

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

let trendChart=null, catChart=null;

async function loadDashboard() {
  const stats = await apiCall('/api/stats/summary');
  if (stats) {
    document.getElementById('stat-monthly-expenses').textContent = formatCurrency(stats.monthly_expenses);
    document.getElementById('stat-monthly-income').textContent = formatCurrency(stats.monthly_income);
    document.getElementById('stat-left-after-bills').textContent = formatCurrency(stats.left_after_bills);
    document.getElementById('stat-unpaid-bills').textContent = formatCurrency(stats.unpaid_bills_total);
    document.getElementById('stat-cc-balance').textContent = formatCurrency(stats.total_credit_card_balance);
    document.getElementById('stat-total-income').textContent = formatCurrency(stats.total_income);
  }
  loadTrendChart();
  loadCategoryChart();
}

async function loadTrendChart() {
  const res = await apiCall('/api/stats/monthly-trend');
  if (!res) return;
  const labels = res.data.map(r => r.month);
  const exp = res.data.map(r => r.expenses);
  const inc = res.data.map(r => r.income);
  const ctx = document.getElementById('trend-chart').getContext('2d');
  if (trendChart) trendChart.destroy();
  trendChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {label:'Expenses', data:exp, borderColor:'#ef4444', backgroundColor:'rgba(239,68,68,0.1)', tension:0.4, fill:true},
        {label:'Income', data:inc, borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.1)', tension:0.4, fill:true}
      ]
    },
    options: { responsive:true, plugins:{legend:{position:'top'}}, scales:{y:{beginAtZero:true}} }
  });
}

async function loadCategoryChart() {
  const now = new Date();
  const month = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const res = await apiCall(`/api/stats/spending-by-category?month=${month}`);
  if (!res || !res.data.length) return;
  const ctx = document.getElementById('category-chart').getContext('2d');
  if (catChart) catChart.destroy();
  catChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: res.data.map(r=>r.category),
      datasets: [{data: res.data.map(r=>r.total),
        backgroundColor:['#667eea','#764ba2','#10b981','#ef4444','#f59e0b','#06b6d4','#8b5cf6','#ec4899','#f97316','#14b8a6','#84cc16']}]
    },
    options: {responsive:true, plugins:{legend:{position:'bottom'}}}
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// EXPENSES
// ═══════════════════════════════════════════════════════════════════════════

async function loadExpenses() {
  const start = document.getElementById('expense-filter-start').value;
  const end = document.getElementById('expense-filter-end').value;
  const cat = document.getElementById('expense-filter-category').value;
  let url = '/api/expenses?';
  if (start) url += `start_date=${start}&`;
  if (end) url += `end_date=${end}&`;
  if (cat) url += `category=${encodeURIComponent(cat)}&`;
  const res = await apiCall(url);
  if (!res) return;
  const tbody = document.getElementById('expense-list');
  if (!res.data.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="empty-state"><div class="icon">💸</div>No expenses found</td></tr>';
    return;
  }
  tbody.innerHTML = res.data.map(e => `
    <tr>
      <td>${formatDate(e.date)}</td>
      <td><span class="badge badge-primary">${e.category}</span></td>
      <td>${e.description}</td>
      <td class="amount-negative">${formatCurrency(e.amount)}</td>
      <td>${e.paid_by}</td>
      <td>${e.payment_method || '-'}</td>
      <td>
        <button class="btn-sm btn-warning" onclick="editExpense(${e.id})">✏️</button>
        <button class="btn-sm btn-danger" onclick="deleteExpense(${e.id}, '${e.description.replace(/'/g,"\\'")}')">🗑️</button>
      </td>
    </tr>`).join('');
}

function clearExpenseFilter() {
  document.getElementById('expense-filter-start').value = '';
  document.getElementById('expense-filter-end').value = '';
  document.getElementById('expense-filter-category').value = '';
  loadExpenses();
}

async function submitExpenseForm(e) {
  e.preventDefault();
  clearFormErrors();
  const editId = document.getElementById('expense-edit-id').value;
  const data = {
    date: document.getElementById('expense-date').value,
    category: document.getElementById('expense-category').value,
    description: document.getElementById('expense-description').value.trim(),
    amount: document.getElementById('expense-amount').value,
    paid_by: document.getElementById('expense-paid-by').value,
    payment_method: document.getElementById('expense-payment-method').value,
    credit_card_id: document.getElementById('expense-credit-card').value || null,
    notes: document.getElementById('expense-notes').value
  };
  let res;
  if (editId) {
    res = await apiCall(`/api/expenses/${editId}`, 'PUT', data);
    if (res) { showToast('success','Expense updated'); cancelExpenseEdit(); loadExpenses(); }
  } else {
    res = await apiCall('/api/expenses', 'POST', data);
    if (res) { showToast('success','Expense added'); document.getElementById('expense-form').reset(); setDefaultDates(); loadExpenses(); }
  }
}

async function editExpense(id) {
  const res = await apiCall('/api/expenses');
  if (!res) return;
  const exp = res.data.find(e => e.id === id);
  if (!exp) return;
  document.getElementById('expense-date').value = exp.date;
  document.getElementById('expense-category').value = exp.category;
  document.getElementById('expense-description').value = exp.description;
  document.getElementById('expense-amount').value = exp.amount;
  document.getElementById('expense-paid-by').value = exp.paid_by;
  document.getElementById('expense-payment-method').value = exp.payment_method || '';
  document.getElementById('expense-credit-card').value = exp.credit_card_id || '';
  document.getElementById('expense-notes').value = exp.notes || '';
  document.getElementById('expense-edit-id').value = id;
  document.getElementById('expense-submit-btn').textContent = '💾 Update Expense';
  document.getElementById('expense-form').scrollIntoView({behavior:'smooth'});
}

function cancelExpenseEdit() {
  document.getElementById('expense-form').reset();
  document.getElementById('expense-edit-id').value = '';
  document.getElementById('expense-submit-btn').textContent = '💾 Add Expense';
  setDefaultDates();
}

function deleteExpense(id, desc) {
  showModal('Delete Expense', `Delete "${desc}"? This cannot be undone.`, async () => {
    const res = await apiCall(`/api/expenses/${id}`, 'DELETE');
    if (res) { showToast('success','Expense deleted'); loadExpenses(); }
  });
}

function exportExpensesCSV(useReportDates=false) {
  let url = '/api/export/expenses/csv?';
  if (useReportDates) {
    const s = document.getElementById('report-start').value;
    const e = document.getElementById('report-end').value;
    if (s) url += `start_date=${s}&`;
    if (e) url += `end_date=${e}&`;
  }
  window.location.href = url;
}

function exportExpensesExcel() { window.location.href = '/api/export/expenses/excel'; }
function exportIncomeCSV() { window.location.href = '/api/export/income/csv'; }

// ═══════════════════════════════════════════════════════════════════════════
// INCOME
// ═══════════════════════════════════════════════════════════════════════════

async function loadIncome() {
  const res = await apiCall('/api/income');
  if (!res) return;
  const tbody = document.getElementById('income-list');
  if (!res.data.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty-state"><div class="icon">💵</div>No income yet</td></tr>';
    return;
  }
  tbody.innerHTML = res.data.map(i => `
    <tr>
      <td>${formatDate(i.date)}</td>
      <td><span class="badge badge-success">${i.source}</span></td>
      <td>${i.description}</td>
      <td class="amount-positive">${formatCurrency(i.amount)}</td>
      <td>${i.received_by}</td>
      <td>
        <button class="btn-sm btn-warning" onclick="editIncome(${i.id})">✏️</button>
        <button class="btn-sm btn-danger" onclick="deleteIncome(${i.id},'${i.description.replace(/'/g,"\\'")}')">🗑️</button>
      </td>
    </tr>`).join('');
}

async function submitIncomeForm(e) {
  e.preventDefault();
  const editId = document.getElementById('income-edit-id').value;
  const data = {
    date: document.getElementById('income-date').value,
    source: document.getElementById('income-source').value,
    description: document.getElementById('income-description').value.trim(),
    amount: document.getElementById('income-amount').value,
    received_by: document.getElementById('income-received-by').value,
    notes: document.getElementById('income-notes').value
  };
  let res;
  if (editId) {
    res = await apiCall(`/api/income/${editId}`, 'PUT', data);
    if (res) { showToast('success','Income updated'); cancelIncomeEdit(); loadIncome(); }
  } else {
    res = await apiCall('/api/income', 'POST', data);
    if (res) {
      showToast('success','Income recorded!');
      if (parseFloat(data.amount) >= 1000) showConfetti();
      document.getElementById('income-form').reset();
      setDefaultDates();
      loadIncome();
    }
  }
}

async function editIncome(id) {
  const res = await apiCall('/api/income');
  if (!res) return;
  const inc = res.data.find(i => i.id === id);
  if (!inc) return;
  document.getElementById('income-date').value = inc.date;
  document.getElementById('income-source').value = inc.source;
  document.getElementById('income-description').value = inc.description;
  document.getElementById('income-amount').value = inc.amount;
  document.getElementById('income-received-by').value = inc.received_by;
  document.getElementById('income-notes').value = inc.notes || '';
  document.getElementById('income-edit-id').value = id;
  document.getElementById('income-submit-btn').textContent = '💾 Update Income';
  document.getElementById('income-form').scrollIntoView({behavior:'smooth'});
}

function cancelIncomeEdit() {
  document.getElementById('income-form').reset();
  document.getElementById('income-edit-id').value = '';
  document.getElementById('income-submit-btn').textContent = '💾 Add Income';
  setDefaultDates();
}

function deleteIncome(id, desc) {
  showModal('Delete Income', `Delete "${desc}"?`, async () => {
    const res = await apiCall(`/api/income/${id}`, 'DELETE');
    if (res) { showToast('success','Income deleted'); loadIncome(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// CREDIT CARDS
// ═══════════════════════════════════════════════════════════════════════════

async function loadCreditCards() {
  const res = await apiCall('/api/credit-cards');
  if (!res) return;
  const grid = document.getElementById('credit-card-list');
  if (!res.data.length) {
    grid.innerHTML = '<div class="empty-state"><div class="icon">💳</div>No credit cards added</div>';
    return;
  }
  grid.innerHTML = res.data.map(c => {
    const util = c.utilization;
    const utilClass = util > 80 ? 'danger' : '';
    return `
    <div class="cc-card">
      <div class="cc-name">${c.card_name}</div>
      <div class="cc-owner">👤 ${c.owner}</div>
      <div class="cc-balance">${formatCurrency(c.balance)}</div>
      <div class="cc-limit">${c.credit_limit ? `Limit: ${formatCurrency(c.credit_limit)}` : 'No limit set'}</div>
      ${c.credit_limit ? `
      <div class="cc-util-bar">
        <div class="cc-util-fill ${utilClass}" style="width:${Math.min(util||0,100)}%"></div>
      </div>
      <div style="font-size:0.78rem;opacity:0.85;margin-top:0.25rem;">${util||0}% utilization</div>` : ''}
      <div class="cc-actions">
        <button onclick="editCreditCard(${c.id})">✏️ Edit</button>
        <button onclick="deleteCreditCard(${c.id},'${c.card_name}')">🗑️ Delete</button>
      </div>
    </div>`;
  }).join('');
  populateCreditCardDropdowns();
}

async function submitCreditCardForm(e) {
  e.preventDefault();
  const editId = document.getElementById('cc-edit-id').value;
  const data = {
    owner: document.getElementById('credit-card-owner').value,
    card_name: document.getElementById('credit-card-name').value.trim(),
    credit_limit: document.getElementById('credit-card-limit').value || null,
    manual_balance: document.getElementById('credit-card-manual-balance').value || null
  };
  let res;
  if (editId) {
    res = await apiCall(`/api/credit-cards/${editId}`, 'PUT', data);
    if (res) { showToast('success','Card updated'); document.getElementById('credit-card-form').reset(); document.getElementById('cc-edit-id').value=''; loadCreditCards(); }
  } else {
    res = await apiCall('/api/credit-cards', 'POST', data);
    if (res) { showToast('success','Card added'); document.getElementById('credit-card-form').reset(); loadCreditCards(); }
  }
}

async function editCreditCard(id) {
  const res = await apiCall('/api/credit-cards');
  if (!res) return;
  const card = res.data.find(c => c.id === id);
  if (!card) return;
  document.getElementById('credit-card-owner').value = card.owner;
  document.getElementById('credit-card-name').value = card.card_name;
  document.getElementById('credit-card-limit').value = card.credit_limit || '';
  document.getElementById('credit-card-manual-balance').value = card.manual_balance || '';
  document.getElementById('cc-edit-id').value = id;
  document.getElementById('credit-card-form').scrollIntoView({behavior:'smooth'});
}

function deleteCreditCard(id, name) {
  showModal('Delete Card', `Delete "${name}"? Expense associations will be cleared.`, async () => {
    const res = await apiCall(`/api/credit-cards/${id}`, 'DELETE');
    if (res) { showToast('success','Card deleted'); loadCreditCards(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// BUDGETS
// ═══════════════════════════════════════════════════════════════════════════

async function loadBudgets() {
  const res = await apiCall('/api/budgets');
  if (!res) return;
  const container = document.getElementById('budget-list');
  if (!res.data.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">🎯</div>No budgets set</div>';
    return;
  }
  const months = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  container.innerHTML = res.data.map(b => `
    <div class="budget-item">
      <div class="budget-info">
        <div>
          <strong>${b.category}</strong>
          <span style="color:var(--text-secondary);font-size:0.85rem;margin-left:0.5rem;">${months[b.month]} ${b.year}</span>
        </div>
        <div style="text-align:right;">
          <span class="${b.is_over?'amount-negative':'amount-positive'}">${formatCurrency(b.spent)}</span>
          <span style="color:var(--text-secondary);"> / ${formatCurrency(b.amount)}</span>
          <span class="badge ${b.is_over?'badge-danger':'badge-primary'}" style="margin-left:0.5rem;">${b.percentage}%</span>
          <button class="btn-sm btn-danger" style="margin-left:0.5rem;" onclick="deleteBudget(${b.id})">🗑️</button>
        </div>
      </div>
      <div class="budget-progress">
        <div class="budget-fill ${b.is_over?'over':''}" style="width:${Math.min(b.percentage,100)}%"></div>
      </div>
    </div>`).join('');
}

async function submitBudgetForm(e) {
  e.preventDefault();
  const data = {
    category: document.getElementById('budget-category').value,
    amount: document.getElementById('budget-amount').value,
    month: document.getElementById('budget-month').value,
    year: document.getElementById('budget-year').value
  };
  const res = await apiCall('/api/budgets', 'POST', data);
  if (res) { showToast('success','Budget set'); document.getElementById('budget-form').reset(); loadBudgets(); }
}

function deleteBudget(id) {
  showModal('Delete Budget','Delete this budget?', async () => {
    const res = await apiCall(`/api/budgets/${id}`, 'DELETE');
    if (res) { showToast('success','Budget deleted'); loadBudgets(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// BILLS
// ═══════════════════════════════════════════════════════════════════════════

async function loadBills() {
  const res = await apiCall('/api/bills');
  if (!res) return;
  const container = document.getElementById('bills-list');
  if (!res.data.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">📅</div>No bills added</div>';
    return;
  }
  container.innerHTML = res.data.map(b => {
    const d = b.days_until;
    const dueCls = d < 0 ? 'overdue' : d <= 7 ? 'soon' : '';
    const dueLabel = d === null ? '' : d < 0 ? `${Math.abs(d)} days overdue` : d === 0 ? 'Due today' : `Due in ${d} days`;
    return `
    <div class="bill-item ${b.is_paid?'paid':''}">
      <div>
        <strong>${b.name}</strong>
        ${b.category?`<span class="badge badge-primary" style="margin-left:0.5rem;">${b.category}</span>`:''}
        <div class="bill-due ${dueCls}">${formatDate(b.due_date)} — ${dueLabel}</div>
      </div>
      <div class="flex-gap">
        <strong class="${b.is_paid?'':'amount-negative'}">${formatCurrency(b.amount)}</strong>
        <button class="btn-sm ${b.is_paid?'btn-secondary':'btn-success'}" onclick="toggleBillPaid(${b.id})">${b.is_paid?'↩️ Unpay':'✅ Pay'}</button>
        <button class="btn-sm btn-danger" onclick="deleteBill(${b.id},'${b.name.replace(/'/g,"\\'")}')">🗑️</button>
      </div>
    </div>`;
  }).join('');
}

async function submitBillForm(e) {
  e.preventDefault();
  const data = {
    name: document.getElementById('bill-name').value.trim(),
    amount: document.getElementById('bill-amount').value,
    due_date: document.getElementById('bill-due-date').value,
    category: document.getElementById('bill-category').value,
    notes: document.getElementById('bill-notes').value
  };
  const res = await apiCall('/api/bills', 'POST', data);
  if (res) { showToast('success','Bill added'); document.getElementById('bill-form').reset(); loadBills(); }
}

async function toggleBillPaid(id) {
  const res = await apiCall(`/api/bills/${id}/toggle`, 'POST');
  if (res) loadBills();
}

function deleteBill(id, name) {
  showModal('Delete Bill', `Delete bill "${name}"?`, async () => {
    const res = await apiCall(`/api/bills/${id}`, 'DELETE');
    if (res) { showToast('success','Bill deleted'); loadBills(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// RECURRING
// ═══════════════════════════════════════════════════════════════════════════

async function loadRecurring() {
  const res = await apiCall('/api/recurring');
  if (!res) return;
  const container = document.getElementById('recurring-list');
  if (!res.data.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">🔄</div>No recurring transactions</div>';
    return;
  }
  container.innerHTML = `<div class="glass-card"><div class="card-title">Scheduled Transactions</div>` +
    res.data.map(r => `
    <div class="bill-item">
      <div>
        <strong>${r.description}</strong>
        <span class="badge badge-${r.type==='income'?'success':'danger'}" style="margin-left:0.5rem;">${r.type}</span>
        <span class="badge badge-primary" style="margin-left:0.25rem;">${r.frequency}</span>
        <div class="bill-due">Next: ${formatDate(r.next_date)} — ${r.person}</div>
      </div>
      <div class="flex-gap">
        <strong class="${r.type==='income'?'amount-positive':'amount-negative'}">${formatCurrency(r.amount)}</strong>
        <button class="btn-sm btn-success" onclick="processRecurring(${r.id},'${r.description.replace(/'/g,"\\'")}')">▶ Process</button>
        <button class="btn-sm btn-danger" onclick="deleteRecurring(${r.id},'${r.description.replace(/'/g,"\\'")}')">🗑️</button>
      </div>
    </div>`).join('') + '</div>';
}

async function submitRecurringForm(e) {
  e.preventDefault();
  const data = {
    type: document.getElementById('rec-type').value,
    frequency: document.getElementById('rec-frequency').value,
    next_date: document.getElementById('rec-next-date').value,
    description: document.getElementById('rec-description').value,
    amount: document.getElementById('rec-amount').value,
    category: document.getElementById('rec-category').value,
    person: document.getElementById('rec-person').value
  };
  const res = await apiCall('/api/recurring', 'POST', data);
  if (res) { showToast('success','Recurring transaction saved'); document.getElementById('recurring-form').reset(); setDefaultDates(); loadRecurring(); }
}

function processRecurring(id, desc) {
  showModal('Process Transaction', `Process "${desc}" now? It will be added to your records.`, async () => {
    const res = await apiCall(`/api/recurring/${id}/process`, 'POST');
    if (res) { showToast('success', res.message || 'Processed successfully'); loadRecurring(); }
  });
}

function deleteRecurring(id, desc) {
  showModal('Delete Recurring', `Delete "${desc}"?`, async () => {
    const res = await apiCall(`/api/recurring/${id}`, 'DELETE');
    if (res) { showToast('success','Deleted'); loadRecurring(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// REPORTS
// ═══════════════════════════════════════════════════════════════════════════

async function generateMonthlyReport() {
  const res = await apiCall('/api/stats/monthly-trend');
  if (!res) return;
  const body = document.getElementById('monthly-report-body');
  body.innerHTML = `<table class="expense-table">
    <thead><tr><th>Month</th><th>Income</th><th>Expenses</th><th>Net</th></tr></thead>
    <tbody>${res.data.map(r => {
      const net = r.income - r.expenses;
      return `<tr>
        <td>${r.month}</td>
        <td class="amount-positive">${formatCurrency(r.income)}</td>
        <td class="amount-negative">${formatCurrency(r.expenses)}</td>
        <td class="${net>=0?'amount-positive':'amount-negative'}">${formatCurrency(net)}</td>
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

// ═══════════════════════════════════════════════════════════════════════════
// ACCOUNT / USERS
// ═══════════════════════════════════════════════════════════════════════════

async function changePassword(e) {
  e.preventDefault();
  const current = document.getElementById('current-password').value;
  const newPass = document.getElementById('new-password').value;
  const confirm = document.getElementById('confirm-password').value;
  if (newPass !== confirm) { showToast('error', 'New passwords do not match'); return; }
  if (newPass.length < 8) { showToast('error', 'Password must be at least 8 characters'); return; }
  const res = await apiCall('/api/users/change-password', 'POST', {current_password: current, new_password: newPass});
  if (res) { showToast('success', 'Password changed!'); document.getElementById('password-form').reset(); }
}

async function loadUsers() {
  const me = await apiCall('/api/auth/me');
  if (!me) return;
  if (me.user.is_admin) {
    document.getElementById('user-management-card').style.display = 'block';
    const res = await apiCall('/api/users');
    if (!res) return;
    const container = document.getElementById('users-list');
    container.innerHTML = `<table class="expense-table">
      <thead><tr><th>Username</th><th>Role</th><th>Created</th><th>Actions</th></tr></thead>
      <tbody>${res.data.map(u => `
        <tr>
          <td>${u.username}</td>
          <td><span class="badge ${u.is_admin?'badge-danger':'badge-primary'}">${u.is_admin?'Admin':'User'}</span></td>
          <td>${u.created_at ? u.created_at.split('T')[0] : ''}</td>
          <td>${u.id !== me.user.id ? `<button class="btn-sm btn-danger" onclick="deleteUser(${u.id},'${u.username}')">🗑️</button>` : '<em style="color:var(--text-tertiary)">You</em>'}</td>
        </tr>`).join('')}
      </tbody></table>`;
  }
}

async function createUser(e) {
  e.preventDefault();
  const data = {
    username: document.getElementById('new-username').value.trim(),
    password: document.getElementById('new-user-password').value,
    is_admin: document.getElementById('new-user-admin').checked
  };
  const res = await apiCall('/api/users', 'POST', data);
  if (res) { showToast('success','User created'); document.getElementById('new-user-form').reset(); loadUsers(); }
}

function deleteUser(id, name) {
  showModal('Delete User', `Delete user "${name}"? This cannot be undone.`, async () => {
    const res = await apiCall(`/api/users/${id}`, 'DELETE');
    if (res) { showToast('success','User deleted'); loadUsers(); }
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// CONFETTI 🎉
// ═══════════════════════════════════════════════════════════════════════════

function showConfetti() {
  for (let i = 0; i < 80; i++) {
    const el = document.createElement('div');
    el.style.cssText = `position:fixed;width:8px;height:8px;border-radius:2px;pointer-events:none;z-index:9999;
      top:-10px;left:${Math.random()*100}vw;
      background:hsl(${Math.random()*360},80%,60%);
      animation:confettiFall ${1+Math.random()*2}s linear forwards;`;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(), 3000);
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════════════════

function setDefaultDates() {
  const t = today();
  ['expense-date','income-date','bill-due-date','rec-next-date'].forEach(id => {
    const el = document.getElementById(id);
    if (el && !el.value) el.value = t;
  });
  // Set default budget month/year
  const now = new Date();
  const bm = document.getElementById('budget-month');
  const by = document.getElementById('budget-year');
  if (bm && !bm.value) bm.value = now.getMonth() + 1;
  if (by && !by.value) by.value = now.getFullYear();
}

let currentUser = '';

async function init() {
  // Theme
  if (localStorage.getItem('theme') === 'dark') {
    document.body.classList.add('dark-mode');
    document.getElementById('theme-toggle').textContent = '☀️';
  }
  // User greeting
  const me = await apiCall('/api/auth/me');
  if (me) {
    currentUser = me.user.username;
    document.getElementById('user-greeting').textContent = `Hi, ${currentUser}`;
  }
  // Load data
  await loadCategories();
  await populateUserDropdowns();
  await populateCreditCardDropdowns();
  setDefaultDates();
  loadDashboard();
}

// Add confetti keyframe
const style = document.createElement('style');
style.textContent = '@keyframes confettiFall { to { transform: translateY(100vh) rotate(720deg); opacity:0; } }';
document.head.appendChild(style);

init();
</script>
</body>
</html>
